{
  "name": "tariffa",
  "version": "0.1.0",
  "private": true,
  "description": "tariffa — AI agent pipeline for Nigerian import documentation. Monorepo root: shared tooling and quality gate.",
  "scripts": {
    "prepare": "husky",
    "lint": "pnpm --filter web run lint",
    "typecheck": "pnpm --filter web run typecheck",
    "format": "prettier --write \"apps/web/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"apps/web/**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx,js,jsx}": [
      "pnpm --filter web exec eslint --fix",
      "prettier --write"
    ],
    "apps/web/**/*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.4.2"
  }
}
